<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.BarangayPantal" parent="Theme.Material3.Light.NoActionBar">
        <!-- Customize your light theme here. -->
        <item name="colorPrimary">@color/green_500</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/blue_500</item>
        <item name="colorTertiary">@color/green_500</item>
        <item name="colorSecondaryContainer">@color/primary_blue_light</item>
        <item name="colorSurface">@color/screen_background</item>
        <item name="android:windowBackground">@color/screen_background</item>
    </style>

    <style name="Theme.BarangayPantal" parent="Base.Theme.BarangayPantal" />

    <style name="Theme.BarangayPantal.NoActionBar" parent="Theme.BarangayPantal" />

    <style name="Theme.BarangayPantal.AppBarOverlay" parent="ThemeOverlay.AppCompat.Dark.ActionBar" />

    <style name="Theme.BarangayPantal.PopupOverlay" parent="ThemeOverlay.AppCompat.Light" />

    <style name="Theme.BarangayPantal.Login" parent="Theme.Material3.Light.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowBackground">@color/white</item>
        <item name="colorPrimary">@color/purple_login</item>
        <item name="colorOnSurface">@color/black</item>
        <item name="colorSurface">@color/white</item>
    </style>
</resources>
